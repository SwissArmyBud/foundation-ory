# Use to control environment variables for docker compose at runtime (interpolation)
# SOME_ENV_VAR=${SOME_ENV_VAR:-true}

###############
### REQUIRED VARIABLES
# Root domain to hang the project off of
SERVICE_DOMAIN=${SERVICE_DOMAIN:?Must configure a base domain that you have DNS control over}
# Contact email for Traefik certificate resolver
ACME_CERTIFICATE_EMAIL=${ACME_CERTIFICATE_EMAIL:?Must have an email for Lets Encrypt TLS certificates}

###############
### STACK VERSIONS
# POSTGRES
POSTGRES_VERSION=${POSTGRES_VERSION:-18.3}
# ORY
ORY_VERSION=${ORY_VERSION:-26.2.0}
# TRAEFIK
TRAEFIK_VERSION=${TRAEFIK_VERSION:-3.6}

###############
### POSTGRES
# Cluster defaults
POSTGRES_USER=${POSTGRES_USER:-orydbuser}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-orydbpass}
POSTGRES_DB=${POSTGRES_DB:-postgres}
# Service databases
POSTGRES_KRATOS_DB=${POSTGRES_KRATOS_DB:-kratos}
POSTGRES_HYDRA_DB=${POSTGRES_HYDRA_DB:-hydra}
POSTGRES_KETO_DB=${POSTGRES_KETO_DB:-keto}

###############
### ORY
## KRATOS
KRATOS_COOKIE_SECRET=${KRATOS_COOKIE_SECRET:-PLEASE-CHANGE-ME-I-AM-VERY-INSECURE}
KRATOS_CIPHER_SECRET=${KRATOS_CIPHER_SECRET:-32-LONG-SECRET-NOT-SECURE-AT-ALL}

###############
### TRAEFIK
# ADMIN ENTRYPOINT
ADMIN_PORT=${ADMIN_PORT:-1443}
# Default ACME resolver for Traefik (stg/prd)
ACME_DEFAULT_RESOLVER=${ACME_DEFAULT_RESOLVER:-stg}
# Routing identifiers
## TRAEFIK
TRAEFIK_SUBDOMAIN=${TRAEFIK_PUBLC_SUBDOMAIN:-traefik}
## KRATOS
KRATOS_PUBLIC_PATH=${KRATOS_PUBLIC_PATH:-/session}
KRATOS_ADMIN_PATH=${KRATOS_ADMIN_PATH:-/kratos}
## HYDRA
HYDRA_PUBLIC_PATH=${HYDRA_PUBLIC_PATH:-/oauth}
HYDRA_ADMIN_PATH=${HYDRA_ADMIN_PATH:-/hydra}
## KETO
KETO_PUBLIC_PATH=${KETO_PUBLIC_PATH:-/authz}
KETO_ADMIN_PATH=${KETO_ADMIN_PATH:-/keto}
## ORY ADMIN UI
ADMIN_SUBDOMAIN=${ADMIN_SUBDOMAIN:-admin}
## CONSENT UI
CONSENT_SUBDOMAIN=${CONSENT_SUBDOMAIN:-consent}
## MAILSLURP
MAIL_SUBDOMAIN=${SLURP_PUBLIC_PATH:-webmail}
SLURP_SUBDOMAIN=${SLURP_ADMIN_PATH:-slurp}
SMTP_SUBDOMAIN=${SLURP_ADMIN_PATH:-smtp}
## WHOAMI
WHOAMI_PUBLIC_PATH=${WHOAMI_PUBLIC_PATH:-/whoami}
PORTAMI_SUBDOMAIN=${PORTAMI_SUBDOMAIN:-portami}

###############
### SELF SERVICE UI
SELFSERVE_COOKIE_SECRET=${SELFSERVE_COOKIE_SECRET:-PLEASE-CHANGE-ME-I-AM-VERY-INSECURE}
SELFSERVE_CSRF_COOKIE_NAME=${SELFSERVE_CSRF_COOKIE_NAME:-ory_csrf_ui}
SELFSERVE_CSRF_COOKIE_SECRET=${SELFSERVE_CSRF_COOKIE_SECRET:-PLEASE-CHANGE-ME-I-AM-VERY-INSECURE}
